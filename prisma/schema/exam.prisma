model Exam {
    id         String     @id @default(cuid())
    batchId    String
    subjectId  String
    name       String
    totalMarks Int
    passMarks  Int
    examDate   DateTime
    startTime  DateTime
    endTime    DateTime
    status     ExamStatus @default(UPCOMING)
    isDeleted  Boolean    @default(false)
    createdAt  DateTime   @default(now())
    updatedAt  DateTime   @updatedAt

    batch   Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    subject Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    results Result[]
    mark    Mark[]

    @@index([batchId])
}
