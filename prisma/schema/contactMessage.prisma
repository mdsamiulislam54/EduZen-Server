enum ContactStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

model ContactMessage {
  id          String         @id @default(cuid())

  fullName    String
  email       String
  phone       String?
  subject     String
  message     String

  status      ContactStatus  @default(PENDING)

  source      String?        

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([subject])
}