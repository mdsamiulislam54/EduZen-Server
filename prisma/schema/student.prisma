model Student {
  id               String        @id @default(cuid())
  coachingCenterId String
  userId           String        @unique
  name             String
  email            String        @unique
  dateOfBirth      DateTime?
  phone            String        @unique
  image            String?
  rollNumber       String?       @unique
  gender           Gender?
  bloodGroup       BloodGroup?
  enrollmentDate   DateTime      @default(now())
  status           StudentStatus @default(ACTIVE)
  isDeleted        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  coachingCenter CoachingCenter @relation(fields: [coachingCenterId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  batchStudents BatchStudent[]
  marks         Mark[]
  results       Result[]
  attendances   Attendance[]
  studentFees   StudentFee[]

  @@index([coachingCenterId])
  @@index([userId])
  @@index([email])
  @@index([rollNumber])
  @@index([phone])
}

model BatchStudent {
  id             String        @id @default(cuid())
  batchId        String
  studentId      String
  enrollmentDate DateTime      @default(now())
  status         StudentStatus @default(ACTIVE)
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  batch   Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([batchId, studentId])
}

model StudentFee {
  id            String        @id @default(cuid())
  studentId     String
  batchFeeId    String // Directly links to the fee definition (which has batchId)
  amount        Int
  paidAmount    Int           @default(0)
  dueAmount     Int
  paymentStatus PaymentStatus @default(PENDING)
  isDeleted Boolean @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  student  Student  @relation(fields: [studentId], references: [id])
  batchFee BatchFee @relation(fields: [batchFeeId], references: [id])
}
