<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Your Account Details</title>
</head>
<body style="margin:0; padding:0; font-family: Arial, sans-serif; background:#f4f6f8;">
  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center">
        <table width="500" cellpadding="20" cellspacing="0" style="background:#ffffff; margin-top:40px; border-radius:10px;">
          
          <!-- Header -->
          <tr>
            <td align="center">
              <h2 style="margin:0; color:#333;">Your Account Has Been Created 🎉</h2>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="color:#555; font-size:14px; line-height:1.6;">
              <p>Hello <strong><%= name || "User" %></strong>,</p>

              <p>Your coaching center account has been successfully created. Below are your login details:</p>

              <!-- Credentials Box -->
              <div style="background:#f1f3f5; padding:15px; border-radius:8px; margin:20px 0;">
                <p><strong>Email:</strong> <%= email %></p>
                <p><strong>Password:</strong> <%= password %></p>
              </div>

              <p>
                Please login using these credentials and change your password immediately for security purposes.
              </p>

              <p style="margin-top:30px;">
                Regards,<br/>
                <strong>Coaching Platform Team</strong>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="font-size:12px; color:#999;">
              © <%= new Date().getFullYear() %> Coaching Platform. All rights reserved.
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>